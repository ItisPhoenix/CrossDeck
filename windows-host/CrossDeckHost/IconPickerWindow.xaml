<Window x:Class="CrossDeckHost.IconPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose Icon" Height="480" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">
    <Border CornerRadius="12" Background="#080810" BorderBrush="#1F1F23" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom TitleBar Row 0 -->
            <Border Grid.Row="0" Background="#0E0E10" BorderBrush="#1F1F23" BorderThickness="0,0,0,1.5" CornerRadius="11,11,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Choose Built-in Icon" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="✕" Width="24" Height="24" Click="CloseButton_Click" Background="Transparent" Foreground="#FFFFFF" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Icon Grid Row 1 -->
            <ScrollViewer Grid.Row="1" Margin="12" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="IconWrapPanel" Orientation="Horizontal"/>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
