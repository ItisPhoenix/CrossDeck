<Window x:Class="CrossDeckHost.IconPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose Icon" Height="480" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI" FontSize="12" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1">
        <Grid>
            <TextBlock x:Name="EmptyStateText" Text="No built-in icons found." Foreground="{StaticResource Brush.Mist}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
            <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="IconWrapPanel" Orientation="Horizontal"/>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
