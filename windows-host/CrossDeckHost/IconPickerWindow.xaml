<Window x:Class="CrossDeckHost.IconPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose Icon" Height="480" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" Background="Transparent"
        WindowStyle="None"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="16,0,8,0">
                <TextBlock Text="CHOOSE ICON" Foreground="{StaticResource Brush.Paper}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                <Button Style="{StaticResource CaptionButton}" Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True" Click="DialogClose_Click"/>
            </Grid>
            <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyStateText" Text="No built-in icons found." Foreground="{StaticResource Brush.Mist}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
            <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="IconWrapPanel" Orientation="Horizontal"/>
            </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
