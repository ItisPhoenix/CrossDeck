<Window x:Class="CrossDeckHost.PresetPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to CrossDeck" Height="380" Width="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">
    <Border CornerRadius="12" Background="#080810" BorderBrush="#1F1F23" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom TitleBar Row 0 -->
            <Border Grid.Row="0" Background="#0E0E10" BorderBrush="#1F1F23" BorderThickness="0,0,0,1.5" CornerRadius="11,11,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="✦ Welcome to CrossDeck" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="—" Width="24" Height="24" Click="MinimizeButton_Click" Background="Transparent" Foreground="#FFFFFF" BorderThickness="0" Margin="0,0,4,0"/>
                        <Button Content="✕" Width="24" Height="24" Click="CloseButton_Click" Background="Transparent" Foreground="#FFFFFF" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Grid Row 1 -->
            <Grid Grid.Row="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Choose a Default Preset" Foreground="#FFFFFF" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="1" Text="Select a template profile to configure your initial deck layout." Foreground="#FFFFFF" FontSize="13" Opacity="0.7" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card 1: Productivity -->
                    <Button Grid.Column="0" Margin="8,0" Click="Productivity_Click" Background="#0E0E10" BorderBrush="#1F1F23" BorderThickness="1.5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="16">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="💻" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="Productivity" Foreground="#00d4ff" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="Macros for browser, volume adjustments, lock PC, and office workflows." Foreground="#FFFFFF" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Card 2: Streaming -->
                    <Button Grid.Column="1" Margin="8,0" Click="Streaming_Click" Background="#0E0E10" BorderBrush="#1F1F23" BorderThickness="1.5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="16">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="🎙️" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="Streaming" Foreground="#8b5cf6" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="Macros for media triggers, volume control, mic mute, and stream tools." Foreground="#FFFFFF" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Card 3: Blank -->
                    <Button Grid.Column="2" Margin="8,0" Click="Blank_Click" Background="#0E0E10" BorderBrush="#1F1F23" BorderThickness="1.5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="16">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="📄" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="Blank" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="Start with an empty profile. Add your own buttons and macros from scratch." Foreground="#FFFFFF" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
