<Window x:Class="CrossDeckHost.PresetPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to CrossDeck" Height="360" Width="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Choose a Default Preset" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="Select a template profile to configure your initial deck layout." FontSize="13" Opacity="0.7" HorizontalAlignment="Center" Margin="0,0,0,24"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Productivity -->
            <Button Grid.Column="0" Margin="8,0" Click="Productivity_Click" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="16">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="💻" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="Productivity" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Macros for browser, volume adjustments, lock PC, and office workflows." FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Card 2: Streaming -->
            <Button Grid.Column="1" Margin="8,0" Click="Streaming_Click" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="16">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="🎙️" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="Streaming" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Macros for media triggers, volume control, mic mute, and stream tools." FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Card 3: Blank -->
            <Button Grid.Column="2" Margin="8,0" Click="Blank_Click" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="16">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="📄" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="Blank" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Start with an empty profile. Add your own buttons and macros from scratch." FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
