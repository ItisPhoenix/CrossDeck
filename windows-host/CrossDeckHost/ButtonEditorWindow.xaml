<Window x:Class="CrossDeckHost.ButtonEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CrossDeckHost.Controls"
        Title="Configure Button" Height="760" Width="620" MinHeight="520" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip" Background="Transparent"
        WindowStyle="None"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="13" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" CornerRadius="12">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="18,0,10,0">
            <TextBlock Text="CONFIGURE BUTTON" Foreground="{StaticResource Brush.Paper}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
            <Button Style="{StaticResource CaptionButton}" Content="✕" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"
                    WindowChrome.IsHitTestVisibleInChrome="True" Click="DialogClose_Click"/>
        </Grid>
        <ScrollViewer Grid.Row="1" Margin="20,8,20,20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                    <!-- Label Field -->
                    <TextBlock Text="Label" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource Brush.Paper}" Margin="0,0,0,6"/>
                    <TextBox x:Name="LabelInput" Margin="0,0,0,18" Padding="10,8" FontSize="13"/>

                    <!-- Icon Picker -->
                    <TextBlock Text="Icon" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource Brush.Paper}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="IconPathText" Padding="10,8" FontSize="13" IsReadOnly="True" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Style="{StaticResource StandardButton}" Padding="12,8" Margin="0,0,8,0" Click="BrowseIcon_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📂" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Browse"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" x:Name="BuiltinIconBtn" Style="{StaticResource StandardButton}" Padding="12,8" Click="ToggleBuiltinIcons_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎨" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Built-in"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Inline Built-in Icons Drawer Panel -->
                    <Border x:Name="BuiltinIconsDrawer" Background="{StaticResource Brush.Void}" BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" CornerRadius="{StaticResource Radius.Control}" Padding="10" Margin="0,0,0,18" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Select Built-in Icon" FontSize="12" Foreground="{StaticResource Brush.Mist}" Margin="0,0,0,8"/>
                            <ScrollViewer Height="130" VerticalScrollBarVisibility="Auto">
                                <WrapPanel x:Name="IconWrapPanel" Orientation="Horizontal"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- Main Action -->
                    <TextBlock Text="Action Type" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource Brush.Paper}" Margin="0,0,0,6"/>
                    <controls:ActionConfigControl x:Name="MainActionConfig" Margin="0,0,0,20"/>

                    <Border Height="1" Background="{StaticResource Brush.Hairline}" Margin="0,0,0,18"/>

                    <!-- A chain doesn't get a separate long-press action — instead, holding the
                         button is how the chain runs at all (a tap does nothing on Android). -->
                    <TextBlock x:Name="MultiActionLongPressNote"
                               Text="This chain runs when the button is held, not tapped. No separate long-press action for a Multiple Actions button."
                               Foreground="{StaticResource Brush.Mist}" FontSize="12" Margin="0,0,0,18" TextWrapping="Wrap" Visibility="Collapsed"/>

                    <!-- Optional long-press action — same full option set as the main action above -->
                    <StackPanel x:Name="LongPressSection">
                        <TextBlock Text="Long-Press Action" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource Brush.Paper}" Margin="0,0,0,4"/>
                        <TextBlock Text="Fires when the button is held on the phone. Same options as the main action above."
                                   Foreground="{StaticResource Brush.Mist}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <CheckBox x:Name="LongPressEnabledCheck" Content="Enable long-press action" FontSize="13" Margin="0,0,0,10"
                                  Checked="LongPressEnabledCheck_Changed" Unchecked="LongPressEnabledCheck_Changed"/>
                        <controls:ActionConfigControl x:Name="LongPressActionConfig" Visibility="Collapsed" Margin="0,0,0,20"/>
                    </StackPanel>

                    <!-- Save / Delete Actions Grid -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource AccentButton}" Padding="12,10" Click="SaveButton_Click" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image x:Name="SaveButtonIcon" Width="16" Height="16" Margin="0,0,8,0"/>
                                <TextBlock x:Name="SaveButtonGlyph" Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,8,0"/>
                                <TextBlock Text="Save Configuration" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" x:Name="DeleteBtn" Style="{StaticResource DangerButton}" Padding="12,10" Click="DeleteButton_Click" Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image x:Name="DeleteButtonIcon" Width="16" Height="16" Margin="0,0,8,0"/>
                                <TextBlock x:Name="DeleteButtonGlyph" Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,8,0"/>
                                <TextBlock Text="Delete Button" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
