<Window x:Class="CrossDeckHost.ButtonEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CrossDeckHost.Controls"
        Title="Configure Button" Height="500" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="Transparent"
        WindowStyle="None"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" CornerRadius="12">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="16,0,8,0">
            <TextBlock Text="CONFIGURE BUTTON" Foreground="{StaticResource Brush.Paper}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
            <Button Style="{StaticResource CaptionButton}" Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                    WindowChrome.IsHitTestVisibleInChrome="True" Click="DialogClose_Click"/>
        </Grid>
        <ScrollViewer Grid.Row="1" Margin="16,4,16,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                    <!-- Label Field -->
                    <TextBlock Text="Label" FontWeight="SemiBold" Foreground="{StaticResource Brush.Paper}" Margin="0,0,0,4"/>
                    <TextBox x:Name="LabelInput" Margin="0,0,0,12" Padding="6"/>

                    <!-- Icon Picker -->
                    <TextBlock Text="Icon" FontWeight="SemiBold" Foreground="{StaticResource Brush.Paper}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="IconPathText" Padding="6" IsReadOnly="True" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Style="{StaticResource StandardButton}" Content="Browse..." Click="BrowseIcon_Click" Margin="0,0,6,0"/>
                        <Button Grid.Column="2" x:Name="BuiltinIconBtn" Style="{StaticResource StandardButton}" Content="Built-in..." Click="ToggleBuiltinIcons_Click"/>
                    </Grid>

                    <!-- Inline Built-in Icons Drawer Panel -->
                    <Border x:Name="BuiltinIconsDrawer" Background="{StaticResource Brush.Void}" BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" CornerRadius="{StaticResource Radius.Control}" Padding="8" Margin="0,0,0,12" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Select Built-in Icon" FontSize="11" Foreground="{StaticResource Brush.Mist}" Margin="0,0,0,6"/>
                            <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                <WrapPanel x:Name="IconWrapPanel" Orientation="Horizontal"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- Action Type selector -->
                    <TextBlock Text="Action Type" FontWeight="SemiBold" Foreground="{StaticResource Brush.Paper}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ActionTypeCombo" Margin="0,0,0,12" Padding="6" SelectionChanged="ActionTypeCombo_SelectionChanged">
                        <ComboBoxItem Content="Keyboard Shortcut" Tag="hotkey"/>
                        <ComboBoxItem Content="Launch App" Tag="launch_app"/>
                        <ComboBoxItem Content="Media Control" Tag="media_control"/>
                        <ComboBoxItem Content="Open Website" Tag="open_url"/>
                        <ComboBoxItem Content="Run Command" Tag="run_command"/>
                        <ComboBoxItem Content="Text Snippet" Tag="text_snippet"/>
                        <ComboBoxItem Content="Open Folder" Tag="open_folder"/>
                        <ComboBoxItem Content="Multiple Actions" Tag="multi_action"/>
                        <ComboBoxItem Content="Dial / Slider" Tag="dial"/>
                    </ComboBox>

                    <!-- Dynamic Action Parameters Card wrapper -->
                    <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" CornerRadius="{StaticResource Radius.Container}" Padding="12" Margin="0,0,0,16">
                        <Grid>
                            <!-- Keyboard Shortcut Panel -->
                            <StackPanel x:Name="HotkeyPanel" Visibility="Collapsed">
                                <TextBlock Text="Hotkey Combination (e.g. Ctrl,Shift,A)" Foreground="{StaticResource Brush.Mist}" FontSize="11" Margin="0,0,0,4"/>
                                <!-- Background=Void: recessed one level deeper than this card's own Panel tone. -->
                                <TextBox x:Name="HotkeyInput" Padding="6" Background="{StaticResource Brush.Void}"/>
                            </StackPanel>

                            <!-- Launch App Panel -->
                            <StackPanel x:Name="LaunchAppPanel" Visibility="Collapsed">
                                <TextBlock Text="Discovered PC Application" Foreground="{StaticResource Brush.Mist}" FontSize="11" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="PathComboInput" IsEditable="True" Padding="6" Background="{StaticResource Brush.Void}"
                                              DisplayMemberPath="Name" SelectionChanged="PathComboInput_SelectionChanged" TextSearch.TextPath="Name"/>
                                    <Button Grid.Column="1" Style="{StaticResource StandardButton}" Content="Browse..." Click="BrowseApp_Click" Margin="6,0,0,0"/>
                                </Grid>
                            </StackPanel>

                            <!-- Media Control Panel -->
                            <StackPanel x:Name="MediaControlPanel" Visibility="Collapsed">
                                <TextBlock Text="Media Key Trigger" Foreground="{StaticResource Brush.Mist}" FontSize="11" Margin="0,0,0,4"/>
                                <ComboBox x:Name="MediaCommandCombo" Background="{StaticResource Brush.Void}">
                                    <ComboBoxItem Content="Play / Pause" Tag="PlayPause"/>
                                    <ComboBoxItem Content="Next Track" Tag="NextTrack"/>
                                    <ComboBoxItem Content="Previous Track" Tag="PrevTrack"/>
                                    <ComboBoxItem Content="Volume Up" Tag="VolumeUp"/>
                                    <ComboBoxItem Content="Volume Down" Tag="VolumeDown"/>
                                    <ComboBoxItem Content="Mute" Tag="VolumeMute"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Open URL Panel -->
                            <StackPanel x:Name="OpenUrlPanel" Visibility="Collapsed">
                                <TextBlock Text="Target Website URL" Foreground="{StaticResource Brush.Mist}" FontSize="11" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Favicon preview (20×20), hidden until a valid domain is detected -->
                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="{StaticResource Radius.Control}" Background="{StaticResource Brush.Void}" BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Image x:Name="FaviconPreview" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0"/>
                                    </Border>
                                    <TextBox x:Name="UrlInput" Grid.Column="1" TextChanged="UrlInput_TextChanged"/>
                                </Grid>
                                <TextBlock x:Name="FaviconStatusText" Text="" Foreground="{StaticResource Brush.Mist}" FontSize="10" Margin="32,0,0,0"/>
                            </StackPanel>

                            <!-- Run Command Panel -->
                            <StackPanel x:Name="RunCommandPanel" Visibility="Collapsed">
                                <TextBlock Text="Shell / Terminal Command" Foreground="{StaticResource Brush.Mist}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="CommandInput" Padding="6" Background="{StaticResource Brush.Void}"/>
                            </StackPanel>

                            <!-- Text Snippet Panel -->
                            <StackPanel x:Name="TextSnippetPanel" Visibility="Collapsed">
                                <TextBlock Text="Text to Paste" Foreground="{StaticResource Brush.Mist}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="SnippetTextInput" Padding="6" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Background="{StaticResource Brush.Void}"/>
                            </StackPanel>

                            <!-- Folder Panel -->
                            <StackPanel x:Name="FolderPanel" Visibility="Collapsed">
                                <TextBlock Text="Target Folder ID (leave empty to auto-generate)" Foreground="{StaticResource Brush.Mist}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="TargetFolderIdInput" Padding="6" Margin="0,0,0,8" Background="{StaticResource Brush.Void}"/>
                                <Button Style="{StaticResource AccentButton}" Content="Enter Folder in Editor Grid" Click="EnterFolder_Click"/>
                            </StackPanel>

                            <!-- Multi-Action Panel -->
                            <StackPanel x:Name="MultiActionPanel" Visibility="Collapsed">
                                <TextBlock Text="Action Chain" Foreground="{StaticResource Brush.Mist}" FontSize="11" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                <controls:ActionStepListControl x:Name="MultiActionStepList"/>
                            </StackPanel>

                            <!-- Dial Panel -->
                            <StackPanel x:Name="DialPanel" Visibility="Collapsed">
                                <TextBlock Text="Dial / Slider Control target" Foreground="{StaticResource Brush.Mist}" FontSize="11" Margin="0,0,0,4"/>
                                <ComboBox x:Name="DialTargetCombo" Background="{StaticResource Brush.Void}">
                                    <ComboBoxItem Content="Volume Adjust" Tag="volume"/>
                                    <ComboBoxItem Content="Brightness Adjust" Tag="brightness"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Optional long-press action — same line format as the multi-action chain -->
                    <TextBlock Text="Long-Press Action (optional)" FontWeight="SemiBold" Foreground="{StaticResource Brush.Paper}" Margin="0,12,0,4"/>
                    <TextBlock Text="Fires when the button is held on the phone. Same format as the action chain, e.g. &quot;Media Control: VolumeMute&quot;"
                               Foreground="{StaticResource Brush.Mist}" FontSize="11" Margin="0,0,0,4" TextWrapping="Wrap"/>
                    <controls:ActionStepListControl x:Name="LongPressStepList"/>

                    <!-- Save / Delete Actions Grid -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource AccentButton}" Content="Save Configuration" Click="SaveButton_Click" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" x:Name="DeleteBtn" Style="{StaticResource DangerButton}" Content="Delete Button" Click="DeleteButton_Click" Margin="6,0,0,0"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
