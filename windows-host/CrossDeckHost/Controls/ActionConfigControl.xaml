<UserControl x:Class="CrossDeckHost.Controls.ActionConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CrossDeckHost.Controls">
    <StackPanel>
        <ComboBox x:Name="ActionTypeCombo" Margin="0,0,0,14" Padding="10,8" FontSize="13" Height="36" SelectionChanged="ActionTypeCombo_SelectionChanged">
            <ComboBoxItem Content="Keyboard Shortcut" Tag="hotkey"/>
            <ComboBoxItem Content="Launch App" Tag="launch_app"/>
            <ComboBoxItem Content="Media Control" Tag="media_control"/>
            <ComboBoxItem Content="Open Website" Tag="open_url"/>
            <ComboBoxItem Content="Run Command" Tag="run_command"/>
            <ComboBoxItem Content="Text Snippet" Tag="text_snippet"/>
            <ComboBoxItem Content="Open Folder" Tag="open_folder"/>
            <ComboBoxItem Content="Multiple Actions" Tag="multi_action"/>
            <ComboBoxItem x:Name="DialTypeItem" Content="Dial / Slider" Tag="dial"/>
        </ComboBox>

        <Border Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" CornerRadius="{StaticResource Radius.Container}" Padding="14">
            <Grid>
                <!-- Keyboard Shortcut Panel -->
                <StackPanel x:Name="HotkeyPanel" Visibility="Collapsed">
                    <TextBlock Text="Hotkey Combination (e.g. Ctrl,Shift,A)" Foreground="{StaticResource Brush.Mist}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="HotkeyInput" Padding="10,8" FontSize="13" Background="{StaticResource Brush.Void}"/>
                </StackPanel>

                <!-- Launch App Panel -->
                <StackPanel x:Name="LaunchAppPanel" Visibility="Collapsed">
                    <TextBlock Text="Discovered PC Application" Foreground="{StaticResource Brush.Mist}" FontSize="12" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PathComboInput" IsEditable="True" Padding="10,8" FontSize="13" Background="{StaticResource Brush.Void}"
                                  SelectionChanged="PathComboInput_SelectionChanged" TextSearch.TextPath="Name"
                                  MaxDropDownHeight="280">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Loaded="AppRow_Loaded">
                                        <Image Width="18" Height="18" Margin="0,0,8,0" Source="{Binding Icon}"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1" Style="{StaticResource StandardButton}" Padding="12,8" Click="BrowseApp_Click" Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📂" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Browse"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Media Control Panel -->
                <StackPanel x:Name="MediaControlPanel" Visibility="Collapsed">
                    <TextBlock Text="Media Key Trigger" Foreground="{StaticResource Brush.Mist}" FontSize="12" Margin="0,0,0,6"/>
                    <ComboBox x:Name="MediaCommandCombo" Padding="10,8" FontSize="13" Background="{StaticResource Brush.Void}">
                        <ComboBoxItem Content="Play / Pause" Tag="PlayPause"/>
                        <ComboBoxItem Content="Next Track" Tag="NextTrack"/>
                        <ComboBoxItem Content="Previous Track" Tag="PrevTrack"/>
                        <ComboBoxItem Content="Volume Up" Tag="VolumeUp"/>
                        <ComboBoxItem Content="Volume Down" Tag="VolumeDown"/>
                        <ComboBoxItem Content="Mute" Tag="VolumeMute"/>
                    </ComboBox>
                </StackPanel>

                <!-- Open URL Panel -->
                <StackPanel x:Name="OpenUrlPanel" Visibility="Collapsed">
                    <TextBlock Text="Target Website URL" Foreground="{StaticResource Brush.Mist}" FontSize="12" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="30" Height="30" CornerRadius="{StaticResource Radius.Control}" Background="{StaticResource Brush.Void}" BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" Margin="0,0,10,0" VerticalAlignment="Center">
                            <Image x:Name="FaviconPreview" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0"/>
                        </Border>
                        <TextBox x:Name="UrlInput" Grid.Column="1" Padding="10,8" FontSize="13" TextChanged="UrlInput_TextChanged"/>
                    </Grid>
                    <TextBlock x:Name="FaviconStatusText" Text="" Foreground="{StaticResource Brush.Mist}" FontSize="11" Margin="40,0,0,0"/>
                </StackPanel>

                <!-- Run Command Panel -->
                <StackPanel x:Name="RunCommandPanel" Visibility="Collapsed">
                    <TextBlock Text="Shell / Terminal Command" Foreground="{StaticResource Brush.Mist}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="CommandInput" Padding="10,8" FontSize="13" Background="{StaticResource Brush.Void}"/>
                </StackPanel>

                <!-- Text Snippet Panel -->
                <StackPanel x:Name="TextSnippetPanel" Visibility="Collapsed">
                    <TextBlock Text="Text to Paste" Foreground="{StaticResource Brush.Mist}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="SnippetTextInput" Padding="10,8" FontSize="13" Height="64" AcceptsReturn="True" TextWrapping="Wrap" Background="{StaticResource Brush.Void}"/>
                </StackPanel>

                <!-- Folder Panel -->
                <StackPanel x:Name="FolderPanel" Visibility="Collapsed">
                    <TextBlock Text="Target Folder ID (leave empty to auto-generate)" Foreground="{StaticResource Brush.Mist}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TargetFolderIdInput" Padding="10,8" FontSize="13" Margin="0,0,0,10" Background="{StaticResource Brush.Void}"/>
                    <Button x:Name="EnterFolderButton" Style="{StaticResource AccentButton}" Padding="12,8" Click="EnterFolder_Click" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="📁" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Enter Folder in Editor Grid"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Multi-Action Panel -->
                <StackPanel x:Name="MultiActionPanel" Visibility="Collapsed">
                    <TextBlock Text="Action Chain" Foreground="{StaticResource Brush.Mist}" FontSize="12" Margin="0,0,0,6" TextWrapping="Wrap"/>
                    <local:ActionStepListControl x:Name="MultiActionStepList"/>
                </StackPanel>

                <!-- Dial Panel -->
                <StackPanel x:Name="DialPanel" Visibility="Collapsed">
                    <TextBlock Text="Dial / Slider Control target" Foreground="{StaticResource Brush.Mist}" FontSize="12" Margin="0,0,0,6"/>
                    <ComboBox x:Name="DialTargetCombo" Padding="10,8" FontSize="13" Background="{StaticResource Brush.Void}">
                        <ComboBoxItem Content="Volume Adjust" Tag="volume"/>
                        <ComboBoxItem Content="Brightness Adjust" Tag="brightness"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
