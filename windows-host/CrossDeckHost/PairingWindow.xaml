<Window x:Class="CrossDeckHost.PairingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pairing Info" Height="320" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">
    <Border CornerRadius="{StaticResource Radius.Container}" Background="{StaticResource Brush.Void}"
            BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom TitleBar Row 0 -->
            <Border Grid.Row="0" Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.Hairline}"
                    BorderThickness="0,0,0,1.5" CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="✦ CrossDeck Pairing Info" Foreground="{StaticResource Brush.Paper}"
                               FontFamily="Segoe UI Variable, Segoe UI" FontWeight="Bold" FontSize="12"
                               Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="—" Width="24" Height="24" Padding="0" Click="MinimizeButton_Click"
                                Background="Transparent" Foreground="{StaticResource Brush.Paper}" BorderThickness="0" Margin="0,0,4,0"/>
                        <Button Content="✕" Width="24" Height="24" Padding="0" Click="CloseButton_Click"
                                Background="Transparent" Foreground="{StaticResource Brush.Paper}" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Grid Row 1 -->
            <Grid Grid.Row="1" Margin="{StaticResource Space.24}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Manual Text Info -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="Enter these on your phone's pairing screen:" Foreground="{StaticResource Brush.Paper}"
                               TextWrapping="Wrap" Margin="0,0,0,12" FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable, Segoe UI"/>

                    <TextBlock Text="PC IP Address" Foreground="{StaticResource Brush.Mist}" FontWeight="Bold" FontSize="11"/>
                    <TextBlock x:Name="IpText" Foreground="{DynamicResource Brush.Accent}" FontSize="18"
                               FontFamily="Cascadia Mono, Consolas, Courier New" Margin="0,0,0,8"/>

                    <TextBlock Text="Port" Foreground="{StaticResource Brush.Mist}" FontWeight="Bold" FontSize="11"/>
                    <TextBlock x:Name="PortText" Foreground="{DynamicResource Brush.Accent}" FontSize="18"
                               FontFamily="Cascadia Mono, Consolas, Courier New" Margin="0,0,0,8"/>

                    <TextBlock Text="PIN (expires in 5 minutes)" Foreground="{StaticResource Brush.Mist}" FontWeight="Bold" FontSize="11"/>
                    <TextBlock x:Name="PinText" Foreground="{StaticResource Brush.VoltViolet}" FontSize="24"
                               FontFamily="Cascadia Mono, Consolas, Courier New" FontWeight="Bold" Margin="0,0,0,4"/>
                    <!--
                      PIN deliberately stays VoltViolet (fixed brand color, not the live Accent)
                      even when a custom accent is set - the PIN needs to visually stand apart
                      from IP/Port as "the one thing you're about to type on another device,"
                      not blend into whatever color the profile happens to be using.
                    -->

                    <TextBlock Text="Both devices must be on the same WiFi network." Foreground="{StaticResource Brush.Mist}"
                               TextWrapping="Wrap" FontSize="10" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Right Column: QR Scanner Box -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Or Scan QR Code" Foreground="{StaticResource Brush.Paper}" TextWrapping="Wrap"
                               Margin="0,0,0,8" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"
                               FontFamily="Segoe UI Variable, Segoe UI"/>
                    <Border BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1.5"
                            Background="{StaticResource Brush.Panel}" Padding="8" CornerRadius="{StaticResource Radius.Control}">
                        <Image x:Name="QrImage" Width="160" Height="160" Stretch="Uniform"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
