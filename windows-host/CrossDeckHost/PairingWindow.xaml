<Window x:Class="CrossDeckHost.PairingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pairing Info" Height="260" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <StackPanel Margin="24" VerticalAlignment="Center">
        <TextBlock Text="Enter these on your phone's pairing screen:"
                   TextWrapping="Wrap" Margin="0,0,0,16" FontSize="14"/>

        <TextBlock Text="PC IP Address" FontWeight="Bold" FontSize="12" Opacity="0.7"/>
        <TextBlock x:Name="IpText" FontSize="20" FontFamily="Consolas" Margin="0,0,0,12"/>

        <TextBlock Text="Port" FontWeight="Bold" FontSize="12" Opacity="0.7"/>
        <TextBlock x:Name="PortText" FontSize="20" FontFamily="Consolas" Margin="0,0,0,12"/>

        <TextBlock Text="PIN (expires in 5 minutes)" FontWeight="Bold" FontSize="12" Opacity="0.7"/>
        <TextBlock x:Name="PinText" FontSize="28" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,4"/>

        <TextBlock Text="Both devices must be on the same WiFi network."
                   TextWrapping="Wrap" FontSize="11" Opacity="0.6" Margin="0,12,0,0"/>
    </StackPanel>
</Window>
