<Window x:Class="CrossDeckHost.PairingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pairing Info" Height="290" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Column: Manual Text Info -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
            <TextBlock Text="Enter these on your phone's pairing screen:"
                       TextWrapping="Wrap" Margin="0,0,0,12" FontSize="13" FontWeight="SemiBold"/>

            <TextBlock Text="PC IP Address" FontWeight="Bold" FontSize="11" Opacity="0.6"/>
            <TextBlock x:Name="IpText" FontSize="18" FontFamily="Consolas" Margin="0,0,0,8"/>

            <TextBlock Text="Port" FontWeight="Bold" FontSize="11" Opacity="0.6"/>
            <TextBlock x:Name="PortText" FontSize="18" FontFamily="Consolas" Margin="0,0,0,8"/>

            <TextBlock Text="PIN (expires in 5 minutes)" FontWeight="Bold" FontSize="11" Opacity="0.6"/>
            <TextBlock x:Name="PinText" FontSize="24" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,4"/>

            <TextBlock Text="Both devices must be on the same WiFi network."
                       TextWrapping="Wrap" FontSize="10" Opacity="0.5" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Right Column: QR Scanner Box -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Or Scan QR Code" TextWrapping="Wrap" Margin="0,0,0,8" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Border BorderBrush="#CCCCCC" BorderThickness="1" Background="White" Padding="8" CornerRadius="4">
                <Image x:Name="QrImage" Width="160" Height="160" Stretch="Uniform"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>
