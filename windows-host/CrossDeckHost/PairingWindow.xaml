<Window x:Class="CrossDeckHost.PairingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pairing Info" Height="320" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">
    <Border CornerRadius="12" Background="#080810" BorderBrush="#1F1F23" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom TitleBar Row 0 -->
            <Border Grid.Row="0" Background="#0E0E10" BorderBrush="#1F1F23" BorderThickness="0,0,0,1.5" CornerRadius="11,11,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="✦ CrossDeck Pairing Info" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="—" Width="24" Height="24" Click="MinimizeButton_Click" Background="Transparent" Foreground="#FFFFFF" BorderThickness="0" Margin="0,0,4,0"/>
                        <Button Content="✕" Width="24" Height="24" Click="CloseButton_Click" Background="Transparent" Foreground="#FFFFFF" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Grid Row 1 -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Manual Text Info -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="Enter these on your phone's pairing screen:" Foreground="#FFFFFF"
                               TextWrapping="Wrap" Margin="0,0,0,12" FontSize="13" FontWeight="SemiBold"/>

                    <TextBlock Text="PC IP Address" Foreground="#FFFFFF" FontWeight="Bold" FontSize="11" Opacity="0.6"/>
                    <TextBlock x:Name="IpText" Foreground="#00d4ff" FontSize="18" FontFamily="Consolas" Margin="0,0,0,8"/>

                    <TextBlock Text="Port" Foreground="#FFFFFF" FontWeight="Bold" FontSize="11" Opacity="0.6"/>
                    <TextBlock x:Name="PortText" Foreground="#00d4ff" FontSize="18" FontFamily="Consolas" Margin="0,0,0,8"/>

                    <TextBlock Text="PIN (expires in 5 minutes)" Foreground="#FFFFFF" FontWeight="Bold" FontSize="11" Opacity="0.6"/>
                    <TextBlock x:Name="PinText" Foreground="#8b5cf6" FontSize="24" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,4"/>

                    <TextBlock Text="Both devices must be on the same WiFi network." Foreground="#FFFFFF"
                               TextWrapping="Wrap" FontSize="10" Opacity="0.5" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Right Column: QR Scanner Box -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Or Scan QR Code" Foreground="#FFFFFF" TextWrapping="Wrap" Margin="0,0,0,8" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Border BorderBrush="#1F1F23" BorderThickness="1.5" Background="#0E0E10" Padding="8" CornerRadius="8">
                        <Image x:Name="QrImage" Width="160" Height="160" Stretch="Uniform"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
