<Window x:Class="CrossDeckHost.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrossDeck Profile Editor" Height="520" Width="840"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">
    <Border CornerRadius="12" Background="#0C0C0E" BorderBrush="#1F1F24" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom TitleBar Row 0 -->
            <Border Grid.Row="0" Background="#0E0E12" BorderBrush="#1F1F24" BorderThickness="0,0,0,1.2" CornerRadius="11,11,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <!-- Left: Custom Cyber-themed Outlined Rings -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Ellipse Width="12" Height="12" Stroke="#FF5F56" StrokeThickness="1.5" Fill="Transparent" Cursor="Hand" MouseLeftButtonDown="CloseButton_Click" ToolTip="Close"/>
                        <Ellipse Width="12" Height="12" Stroke="#8B5CF6" StrokeThickness="1.5" Fill="Transparent" Margin="8,0,8,0" Cursor="Hand" MouseLeftButtonDown="MinimizeButton_Click" ToolTip="Minimize"/>
                        <Ellipse Width="12" Height="12" Stroke="#00D4FF" StrokeThickness="1.5" Fill="Transparent" ToolTip="Maximize (Disabled)"/>
                    </StackPanel>

                    <!-- Center: Window Title Text -->
                    <TextBlock Text="CrossDeck Host Editor" Foreground="#8A8A93" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="11.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Right: Accent Selector Combo -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0">
                        <TextBlock Text="Theme:" Foreground="#8A8A93" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="AccentCombo" Width="125" Height="22" FontSize="10.5" SelectionChanged="AccentCombo_SelectionChanged" Background="#121216" Foreground="#FFFFFF" BorderBrush="#25252E" VerticalAlignment="Center">
                            <ComboBoxItem Content="Neon Cyan" Tag="#00d4ff"/>
                            <ComboBoxItem Content="Neon Purple" Tag="#8b5cf6"/>
                            <ComboBoxItem Content="Cyberpunk Yellow" Tag="#ffb703"/>
                            <ComboBoxItem Content="Toxic Green" Tag="#2ec4b6"/>
                            <ComboBoxItem Content="Crimson Red" Tag="#e63946"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Split Content Area Row 1 -->
            <Grid Grid.Row="1" Margin="12">
                <Grid.ColumnDefinitions>
                    <!-- Column 0: Left Sidebar (width 220) -->
                    <ColumnDefinition Width="220"/>
                    <!-- Column 1: Main Button Grid (fills the rest) -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <Grid.RowDefinitions>
                        <!-- Top: Connection status card -->
                        <RowDefinition Height="Auto"/>
                        <!-- Middle: Profiles List -->
                        <RowDefinition Height="*"/>
                        <!-- Bottom: Profile tools & Footer -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 1. Phone Connection Card -->
                    <Border Grid.Row="0" Margin="0,0,0,12" Padding="12" Background="#121216" BorderBrush="#1F1F24" BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📱" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Grid>
                                    <TextBlock x:Name="DeviceNameText" Text="Offline" Foreground="#FFFFFF" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    <Ellipse x:Name="ConnectionDot" HorizontalAlignment="Right" Width="8" Height="8" Fill="#FF5555" Margin="0,3,0,0" VerticalAlignment="Top"/>
                                </Grid>
                                <TextBlock x:Name="ConnectionDetailsText" Text="Waiting for client..." Foreground="#8A8A93" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 2. Scrollable Profiles List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ProfileListContainer">
                            <!-- Populated dynamically in code-behind -->
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 3. Sidebar Footer (Profile Control buttons & links) -->
                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <!-- Profile creation triggers -->
                        <Button Content="+ New Profile Page" Click="NewProfileButton_Click" Background="Transparent" BorderBrush="#25252E" BorderThickness="1" Foreground="#8A8A93" Padding="8" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Rename" Click="RenameProfileButton_Click" Margin="0,0,3,0" Padding="6,4" FontSize="10.5"/>
                            <Button Grid.Column="1" Content="Delete Page" Click="DeleteProfileButton_Click" Margin="3,0,0,0" Padding="6,4" FontSize="10.5" Background="#3F1616" Foreground="#FFA0A0" BorderBrush="#601A1A"/>
                        </Grid>
                        
                        <Button Content="Add Preset profile..." Click="AddPresetProfileButton_Click" Margin="0,0,0,12" Padding="6" FontSize="10.5"/>

                        <Border BorderBrush="#1F1F24" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,4,0,0">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Text="About" Foreground="#8A8A93" FontSize="10.5" Cursor="Hand" MouseLeftButtonDown="AboutLink_Click" Margin="0,0,12,0" TextDecorations="Underline"/>
                                    <TextBlock Text="Help &amp; Feedback" Foreground="#8A8A93" FontSize="10.5" Cursor="Hand" MouseLeftButtonDown="HelpLink_Click" TextDecorations="Underline"/>
                                </StackPanel>
                                <TextBlock Text="v1.0" Foreground="#44444F" FontSize="10.5" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- RIGHT MAIN GRID AREA -->
                <Border Grid.Column="1" Background="#121216" BorderBrush="#1F1F24" BorderThickness="1" CornerRadius="12" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- Top: Navigation Header -->
                            <RowDefinition Height="Auto"/>
                            <!-- Middle: Buttons Grid canvas -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Nav & Info Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BackButton" Content="◀ Go Back" VerticalAlignment="Center" Padding="8,4" Click="BackButton_Click" Visibility="Collapsed" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BreadcrumbText" Grid.Column="1" Text="Folder: Root" VerticalAlignment="Center" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>

                            <!-- Trigger Process picker box -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Trigger Process:" Foreground="#8A8A93" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="TriggerProcessTxt" Width="130" Height="22" VerticalAlignment="Center" Padding="3,1" LostFocus="TriggerProcessTxt_LostFocus" KeyDown="TriggerProcessTxt_KeyDown" ToolTip="e.g. chrome.exe (auto-switches to this profile)"/>
                            </StackPanel>
                        </Grid>

                        <!-- Spacious Grid Canvas -->
                        <Grid Grid.Row="1">
                            <UniformGrid x:Name="ButtonGrid" Rows="3" Columns="5">
                                <!-- Dynamic Squircle Buttons added dynamically in C# -->
                            </UniformGrid>

                            <!-- Ambient Connection Notifications Toast Overlay in Bottom-Right -->
                            <Border x:Name="ToastNotificationCard" CornerRadius="8" Background="#1C1C24" BorderBrush="{DynamicResource PrimaryAccentBrush}" BorderThickness="1" Padding="12,8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,16" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="ToastStateDot" Width="8" Height="8" Fill="#FF5555" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="ToastMessageText" Text="Device Disconnected" Foreground="#FFFFFF" FontSize="11.5" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
