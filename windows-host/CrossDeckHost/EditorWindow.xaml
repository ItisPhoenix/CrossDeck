<Window x:Class="CrossDeckHost.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrossDeck" Height="560" Width="900" MinHeight="480" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize" Background="Transparent"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" UseLayoutRounding="True" SnapsToDevicePixels="True">

    <!-- Custom chrome with native resize/snap/shadow -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" CornerRadius="10">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#111118" Offset="0"/>
                <GradientStop Color="#0B0B0F" Offset="0.35"/>
                <GradientStop Color="#0B0B0F" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Margin="16,0,10,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource Brush.Accent}" VerticalAlignment="Center"/>
                    <TextBlock Text="CROSSDECK" Foreground="{StaticResource Brush.Paper}" FontWeight="Bold"
                               FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock.LayoutTransform>
                            <ScaleTransform/>
                        </TextBlock.LayoutTransform>
                    </TextBlock>
                    <TextBlock Text="PROFILE EDITOR" Foreground="{StaticResource Brush.Mist}" FontSize="10.5"
                               Margin="10,1,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionButton}" Content="—" Click="MinimizeButton_Click"/>
                    <Button Style="{StaticResource CaptionButton}" Content="✕" Click="CloseButton_Click" Margin="2,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Main Split Content Area -->
            <Grid Grid.Row="1" Margin="16,4,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <Grid Grid.Column="0" Margin="0,0,14,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 1. Connection / Pairing card -->
                    <Border Grid.Row="0" Margin="0,0,0,12" Padding="14,12" Background="#14141B"
                            BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📱" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Grid>
                                        <TextBlock x:Name="DeviceNameText" Text="Offline" Foreground="{StaticResource Brush.Paper}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <Ellipse x:Name="ConnectionDot" HorizontalAlignment="Right" Width="8" Height="8" Fill="{StaticResource Brush.Alarm}" Margin="0,3,0,0" VerticalAlignment="Top"/>
                                    </Grid>
                                    <TextBlock x:Name="ConnectionDetailsText" Text="Waiting for client..." Foreground="{StaticResource Brush.Mist}" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>

                            <!-- Inline pairing details — visible only while no phone is connected -->
                            <StackPanel x:Name="PairingPanel" Margin="0,12,0,0" Visibility="Collapsed">
                                <Border BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="0,1,0,0" Margin="0,0,0,10"/>
                                <Border Background="White" CornerRadius="8" Padding="6" HorizontalAlignment="Center">
                                    <Image x:Name="QrImage" Width="120" Height="120" Stretch="Uniform"/>
                                </Border>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ADDRESS" Foreground="{StaticResource Brush.Mist}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PairingAddressText" Grid.Column="1" Foreground="{DynamicResource Brush.Accent}" FontSize="12"
                                               FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="PIN" Foreground="{StaticResource Brush.Mist}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PairingPinText" Grid.Column="1" Foreground="{StaticResource Brush.VoltViolet}" FontSize="16" FontWeight="Bold"
                                               FontFamily="Cascadia Mono, Consolas" HorizontalAlignment="Right"/>
                                </Grid>
                                <TextBlock Text="Scan the QR in the phone app, or enter the address + PIN. Same WiFi required."
                                           Foreground="{StaticResource Brush.Mist}" FontSize="9.5" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 2. Scrollable Profiles List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ProfileListContainer"/>
                    </ScrollViewer>

                    <!-- 3. Sidebar Footer -->
                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Theme:" Foreground="{StaticResource Brush.Mist}" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <!-- Tag values here are accent color DATA the user picks from, not chrome. -->
                            <ComboBox x:Name="AccentCombo" Grid.Column="1" Height="28" FontSize="11" SelectionChanged="AccentCombo_SelectionChanged">
                                <ComboBoxItem Content="Neon Cyan" Tag="#00E5FF"/>
                                <ComboBoxItem Content="Neon Purple" Tag="#8b5cf6"/>
                                <ComboBoxItem Content="Cyberpunk Yellow" Tag="#ffb703"/>
                                <ComboBoxItem Content="Toxic Green" Tag="#39FF14"/>
                                <ComboBoxItem Content="Crimson Red" Tag="#e63946"/>
                            </ComboBox>
                        </Grid>

                        <Button Style="{StaticResource AccentButton}" Content="+ New Profile Page" Click="NewProfileButton_Click" Margin="0,0,0,6"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource StandardButton}" Content="Rename" Click="RenameProfileButton_Click" Margin="0,0,3,0"/>
                            <Button Style="{StaticResource DangerButton}" Grid.Column="1" Content="Delete Page" Click="DeleteProfileButton_Click" Margin="3,0,0,0"/>
                        </Grid>

                        <Button Style="{StaticResource StandardButton}" Content="Add Preset profile..." Click="AddPresetProfileButton_Click" Margin="0,0,0,10"/>

                        <CheckBox x:Name="RunOnBootCheck" Content="Start CrossDeck on PC startup" FontSize="11" Margin="2,0,0,12" Checked="RunOnBootCheck_Changed" Unchecked="RunOnBootCheck_Changed"/>

                        <Border BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,4,0,0">
                            <Grid>
                                <TextBlock Text="About" Foreground="{StaticResource Brush.Mist}" FontSize="10.5" Cursor="Hand" MouseLeftButtonDown="AboutLink_Click" TextDecorations="Underline" HorizontalAlignment="Left"/>
                                <TextBlock Text="v0.1.0-beta" Foreground="{StaticResource Brush.Mist}" FontSize="10.5" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- RIGHT MAIN GRID AREA -->
                <Border Grid.Column="1" Background="#0E0E14" BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" CornerRadius="14" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Nav & Info Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BackButton" Style="{StaticResource StandardButton}" Content="◀ Go Back" VerticalAlignment="Center" Click="BackButton_Click" Visibility="Collapsed" Margin="0,0,10,0"/>
                            <StackPanel x:Name="BreadcrumbPanel" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Grid:" Foreground="{StaticResource Brush.Mist}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="GridSizeCombo" Width="80" Height="28" FontSize="11" SelectionChanged="GridSizeCombo_SelectionChanged" VerticalAlignment="Center" Margin="0,0,14,0">
                                    <ComboBoxItem Content="2 × 4" Tag="2,4"/>
                                    <ComboBoxItem Content="3 × 5" Tag="3,5" IsSelected="True"/>
                                    <ComboBoxItem Content="4 × 6" Tag="4,6"/>
                                    <ComboBoxItem Content="2 × 3" Tag="2,3"/>
                                </ComboBox>
                                <TextBlock Text="Trigger:" Foreground="{StaticResource Brush.Mist}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox x:Name="TriggerProcessTxt" Width="120" Height="28" VerticalAlignment="Center" LostFocus="TriggerProcessTxt_LostFocus" KeyDown="TriggerProcessTxt_KeyDown" ToolTip="e.g. chrome.exe (auto-switches to this profile)"/>
                            </StackPanel>
                        </Grid>

                        <!-- Grid Canvas -->
                        <Grid Grid.Row="1">
                            <UniformGrid x:Name="ButtonGrid" Rows="3" Columns="5"/>

                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,16">
                                <Border x:Name="ToastNotificationCard" CornerRadius="10" Background="{StaticResource Brush.Panel}" BorderBrush="{DynamicResource Brush.Accent}" BorderThickness="1" Padding="12,8" Margin="0,0,0,6" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse x:Name="ToastStateDot" Width="8" Height="8" Fill="{StaticResource Brush.Alarm}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="ToastMessageText" Text="Device Disconnected" Foreground="{StaticResource Brush.Paper}" FontSize="11.5" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="UndoToastCard" CornerRadius="10" Background="{StaticResource Brush.Panel}" BorderBrush="{StaticResource Brush.VoltViolet}" BorderThickness="1" Padding="10,6" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="↩" Foreground="{StaticResource Brush.VoltViolet}" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="UndoToastLabel" Text="Undo last edit" Foreground="{StaticResource Brush.Paper}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Button x:Name="UndoBtn" Content="Undo" Click="UndoBtn_Click" Padding="8,3" FontSize="10.5" Background="{StaticResource Brush.VoltViolet}" Foreground="{StaticResource Brush.Paper}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
